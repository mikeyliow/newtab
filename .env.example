# Copy to .env for local dev (all have dev fallbacks when running `npm run dev`).
# In production these MUST be set — the server refuses to fall back outside dev.

# login passcode for the browser (you type this once per device)
PASSCODE=

# long random string that signs the session cookie
JWT_SECRET=

# bearer token for agents calling /mcp (and optionally /api)
MCP_KEY=

# where the SQLite file lives; on Railway set this to /data/newtab.db (volume mount)
DATABASE_PATH=data/newtab.db

# so "today" matches your day, not UTC
TZ=Asia/Kuala_Lumpur
